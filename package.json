{
    "name": "backend---node",
    "version": "1.0.0",
    "main": "app/app.js",
    "type": "module",
    "scripts": {
        "start": "node app.js",
        "dev": "node --watch app.js",
        "dev:postgre":  "node --watch server-with-postgre.js",
        "test": "echo \"Error: no test specified\" && exit 1",
        "migrate": "sequelize-cli db:migrate --config app/config/config.js --migrations-path migrations",
        "migrate:undo": "sequelize-cli db:migrate:undo --config app/config/config.js --migrations-path migrations",
        "migrate:undo:all": "sequelize-cli db:migrate:undo:all --config app/config/config.js --migrations-path migrations",
        "make:migration": "sequelize-cli migration:generate --migrations-path migrations --name"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "engines": {
        "node": ">=18.17.0"
    },
    "dependencies": {
        "bcrypt": "5.1.1",
        "cors": "2.8.5",
        "dotenv": "16.4.7",
        "express": "4.21.2",
        "jsonwebtoken": "9.0.2",
        "morgan": "1.10.0",
        "multer": "^2.0.1",
        "pg": "8.13.1",
        "pg-hstore": "^2.3.4",
        "sequelize": "^6.37.8",
        "uuid": "11.1.0",
        "zod": "3.24.2"
    },
    "devDependencies": {
        "sequelize-cli": "^6.6.5",
        "standard": "17.1.2"
    }
}
